{
  "name": "asanabar",
  "productName": "AsanaBar",
  "version": "0.1.0",
  "description": "Application macOS menu bar pour Asana — voir les commentaires où l'on est mentionné (lire, archiver, ouvrir) et copier les liens de ses tâches du jour",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "keywords": [
    "asana",
    "mentions",
    "menubar",
    "electron",
    "macos",
    "tasks",
    "productivity"
  ],
  "author": {
    "name": "Ludovic Dubois"
  },
  "contributors": [
    {
      "name": "Yoan Bernabeu",
      "email": "ybernabeu@seineyonne.fr"
    }
  ],
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "electron": "40.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "date-fns": "^4.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
